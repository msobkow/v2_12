<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="db2luw"
	Name="schema/dbcreate/db2luw/crtbl_schema_idg16.sql"
	Revision="2.12"
	Descr="IBM DB/2 LUW create schema Id16 generator sql script">

	<GenFile ScopeDef="SchemaDef" GenDef="Id16Gen" Name="dbadminfile_CreateSchemaIdg16Table"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="db2luw"
		ExpansionClassName="crtbl_$lower DbSchemaName$_idg16"
		ExpansionKeyName="crtbl_$lower DbSchemaName$_idg16"
		ExpansionFileName="$dbadminfilename_CreateSchemaIdg16Table$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
CREATE TABLE $lower DbSchemaName$.$DbSchemaName$_idg16 ($ContSqlStmt$	slice_id	SMALLINT$clause_NotNull$,$ContSqlStmt$	next_id	$clause_ColType$$clause_NotNull$ )$ContSqlStmt$IN msidata1$RunSqlStmt$
ALTER TABLE $lower DbSchemaName$.$DbSchemaName$_idg16$ContSqlStmt$	ADD CONSTRAINT pk_$lower DbSchemaName$_idg16 PRIMARY KEY ($ContSqlStmt$		slice_id )$RunSqlStmt$
</GenFile>

</RuleSet>
