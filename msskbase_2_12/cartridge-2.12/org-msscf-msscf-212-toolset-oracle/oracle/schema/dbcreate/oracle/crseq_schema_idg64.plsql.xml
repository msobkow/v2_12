<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="oracle"
	Name="schema/dbcreate/oracle/crseq_schema_idg64.plsql"
	Revision="2.12"
	Descr="Oracle Create Schema Id64 Generator Sequence PL/SQL Script">

	<GenFile ScopeDef="SchemaDef" GenDef="Id64Gen" Name="dbadminfile_CreateSchemaIdg64Sequence"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="oracle"
		ExpansionClassName="crseq_$lower DbColumnName$"
		ExpansionKeyName="crseq_$lower DbColumnName$"
		ExpansionFileName="$dbadminfilename_CreateSchemaIdg64Sequence$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
CREATE SEQUENCE $lower DbSchemaName$.$DbColumnName$
	INCREMENT BY 1
	START WITH 1
	MAXVALUE $switch HasMaxValue yes MaxValue default const9223372036854775807$;
</GenFile>

	<GenRule GenDef="Object" Name="const9223372036854775807">9223372036854775807</GenRule>

</RuleSet>
