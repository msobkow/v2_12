<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="oracle"
	Name="schema/dbcreate/oracle/crsp_is_system_user.oracle"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateSPIsSystemUser"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="oracle"
		ExpansionClassName="$dbadminfilename_CreateSPIsSystemUser$"
		ExpansionKeyName="$dbadminfilename_CreateSPIsSystemUser$"
		ExpansionFileName="$dbadminfilename_CreateSPIsSystemUser$" >--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
alter session set plsql_warnings = 'ENABLE:ALL';
/

create or replace function $lower DbSchemaName$.sp_is_system_user(
	argSecUserId varchar )
return integer authid definer
is
	retval integer;
	cursor curs is
		select
			susr.secuserid as secuserid
		from $lower DbSchemaName$.SecUser susr
		where
				susr.secuserid = argSecUserId
			and susr.login_id = 'system';
begin
	retval := 0;
	for cur in curs
	loop
		retval := 1;
		exit;
	end loop;
	return retval;
end sp_is_system_user;
/

show errors function $lower DbSchemaName$.sp_is_system_user;
</GenFile>

</RuleSet>
