<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="pgsql"
	Name="schema/dbcreate/pgsql/crseq_schema.bat"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateAllSequencesBat"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="pgsql"
		ExpansionClassName="crseq_$lower DbSchemaName$_bat"
		ExpansionKeyName="crseq_$lower DbSchemaName$_bat"
		ExpansionFileName="$dbadminfilename_CreateAllSequencesBat$">@ECHO off
REM
REM	@(#) $GenPackageDir$/$GenFileName$
$MssBatScriptLicense$
$parsePgSqlArgsBat$$validatePgSqlArgsBat$
$iterate Id16Generators( each invoke_CreateSchemaIdg16SequenceBat empty empty )$$iterate Id32Generators( each invoke_CreateSchemaIdg32SequenceBat empty empty )$$iterate Id64Generators( each invoke_CreateSchemaIdg64SequenceBat empty empty )$
</GenFile>

	<GenRule ScopeDef="SchemaDef" GenDef="Id16Gen" Name="invoke_CreateSchemaIdg16SequenceBat">psql -h %pghost% -d %pgdb% -U %pguser% -a -e -f $dbadminfilename_CreateSchemaIdg16Sequence$ &gt;&gt;%logfilename% 2&gt;&amp;1
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Id32Gen" Name="invoke_CreateSchemaIdg32SequenceBat">psql -h %pghost% -d %pgdb% -U %pguser% -a -e -f $dbadminfilename_CreateSchemaIdg32Sequence$ &gt;&gt;%logfilename% 2&gt;&amp;1
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Id64Gen" Name="invoke_CreateSchemaIdg64SequenceBat">psql -h %pghost% -d %pgdb% -U %pguser% -a -e -f $dbadminfilename_CreateSchemaIdg64Sequence$ &gt;&gt;%logfilename% 2&gt;&amp;1
</GenRule>

</RuleSet>
