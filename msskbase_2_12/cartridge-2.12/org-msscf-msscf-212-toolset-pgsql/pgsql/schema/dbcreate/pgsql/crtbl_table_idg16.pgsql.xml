<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="pgsql"
	Name="schema/dbcreate/pgsql/crtbl_table_idg16.pgsql"
	Revision="2.12"
	Descr="null">

	<GenFile ScopeDef="Table" GenDef="Id16Gen" Name="dbadminfile_CreateTableIdg16Table"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="pgsql"
		ExpansionClassName="crtbl_$lower DbTableName$_idg16"
		ExpansionKeyName="crtbl_$lower DbTableName$_idg16"
		ExpansionFileName="$dbadminfilename_CreateTableIdg16Table$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
CREATE TABLE $lower DbSchemaName$.$popto Table DbTableName$_idg16 ($popto Table reference PrimaryKeyIndex iterate Columns( each clause_CreateColComma )$
	slice_id	SMALLINT$clause_NotNull$,
	next_id	$clause_ColType$$clause_NotNull$ )
	WITHOUT OIDS
	TABLESPACE $dataseg_SchemaData1$$RunSqlStmt$
ALTER TABLE $lower DbSchemaName$.$popto Table DbTableName$_idg16
	ADD CONSTRAINT pk_$lower popto Table DbTableName$_idg16 PRIMARY KEY ($popto Table reference PrimaryKeyIndex iterate Columns( each clause_PKeyColComma )$ slice_id )$RunSqlStmt$
</GenFile>

	<GenRule ScopeDef="Index" GenDef="IndexCol" Name="clause_CreateColComma">$clause_CreateCol$,</GenRule>

	<GenRule ScopeDef="Index" GenDef="IndexCol" Name="clause_CreateCol">
	$lower reference Column DbColumnName$	$reference Column clause_ColType$$reference Column switch IsNullable yes clause_Null default clause_NotNull$</GenRule>

</RuleSet>
