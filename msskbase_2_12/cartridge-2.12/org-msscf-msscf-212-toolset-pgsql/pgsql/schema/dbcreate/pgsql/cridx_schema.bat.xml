<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="pgsql"
	Name="schema/dbcreate/pgsql/cridx_schema.bat"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateAllIndexesBat"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="pgsql"
		ExpansionClassName="cridx_$lower SchemaName$_bat"
		ExpansionKeyName="cridx_$lower SchemaName$_bat"
		ExpansionFileName="$dbadminfilename_CreateAllIndexesBat$">@ECHO off
REM
REM	@(#) $GenPackageDir$/$GenFileName$
$MssBatScriptLicense$
$parsePgSqlArgsBat$$validatePgSqlArgsBat$
$iterate SchemaTables( each invoke_CreateTableIndexesBat empty empty )$
</GenFile>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="invoke_CreateTableIndexesBat"
		>$iterate Index( each maybe_CreateIndexBat empty empty )$</GenRule>

	<GenRule GenDef="Index" Name="maybe_CreateIndexBat"
		>$switch IsPrimaryIndex no maybe_CreateMappedIndexBat default empty$</GenRule>

	<GenRule GenDef="Index" Name="maybe_CreateMappedIndexBat"
		>$switch IsDbMapped yes invoke_CreateIndexBat default empty$</GenRule>

	<GenRule GenDef="Index" Name="invoke_CreateIndexBat"
		>psql -h %pghost% -d %pgdb% -U %pguser% -a -e -f $dbadminfilename_CreateIndex$ &gt;&gt;%logfilename% 2&gt;&amp;1
</GenRule>

</RuleSet>
