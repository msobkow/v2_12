			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="pgsql"
		ExpansionClassName="crrel_$lower DbTableName$_idg64"
		ExpansionKeyName="crrel_$lower DbTableName$_idg64"
		ExpansionFileName="$dbadminfilename_CreateTableIdg64Relations$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
ALTER TABLE $lower DbSchemaName$.$DbTableName$_idg64 ADD CONSTRAINT $DbTableName$_idg64_prnt
