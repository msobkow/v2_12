<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="pgsql"
	Name="schema/dbcreate/pgsql/crrel_schema.bash"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateAllRelations"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="pgsql"
		ExpansionClassName="crrel_$lower SchemaName$"
		ExpansionKeyName="crrel_$lower SchemaName$"
		ExpansionFileName="$dbadminfilename_CreateAllRelations$">#!/bin/bash
#
#	@(#) $GenPackageDir$/$GenFileName$
$MssBashScriptLicense$
$parsePgSqlArgs$$validatePgSqlArgs$
$iterate SchemaTables( each invoke_CreateTableRelations empty empty )$
</GenFile>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="invoke_CreateTableRelations">psql -h $${pghost} $${PGPORT} -d $${pgdb} -U $${pguser} -a -e -f $dbadminfilename_CreateTableRelations$ &gt;&gt;$${logfilename} 2&gt;&amp;1
$iterate DispensedId16Generators( first invoke_CreateTableIdgRelations each empty empty empty )$$iterate DispensedId32Generators( first invoke_CreateTableIdgRelations each empty empty empty )$$iterate DispensedId64Generators( first invoke_CreateTableIdgRelations each empty empty empty )$</GenRule>

	<GenRule ScopeDef="Table" GenDef="Id16Gen" Name="invoke_CreateTableIdgRelations">psql -h $${pghost} $${PGPORT} -d $${pgdb} -U $${pguser} -a -e -f $dbadminfilename_CreateTableIdg16Relations$ &gt;&gt;$${logfilename} 2&gt;&amp;1
</GenRule>

	<GenRule ScopeDef="Table" GenDef="Id32Gen" Name="invoke_CreateTableIdgRelations">psql -h $${pghost} $${PGPORT} -d $${pgdb} -U $${pguser} -a -e -f $dbadminfilename_CreateTableIdg32Relations$ &gt;&gt;$${logfilename} 2&gt;&amp;1
</GenRule>

	<GenRule ScopeDef="Table" GenDef="Id64Gen" Name="invoke_CreateTableIdgRelations">psql -h $${pghost} $${PGPORT} -d $${pgdb} -U $${pguser} -a -e -f $dbadminfilename_CreateTableIdg64Relations$ &gt;&gt;$${logfilename} 2&gt;&amp;1
</GenRule>

</RuleSet>
