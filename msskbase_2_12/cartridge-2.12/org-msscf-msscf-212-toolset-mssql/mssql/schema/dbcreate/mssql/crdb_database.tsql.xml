<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mssql"
	Name="schema/dbcreate/mssql/crdb_database.tsql"
	Revision="2.12"
	Descr="Microsoft SQL Server Developer Edition Create Database T-SQL Script">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateDb"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mssql"
		ExpansionClassName="crdb_$lower DbSchemaName$"
		ExpansionKeyName="crdb_$lower DbSchemaName$"
		ExpansionFileName="$dbadminfilename_CreateDb$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
use master
go

create database [$lower DbSchemaName$] on primary
	( 	NAME = N'$lower DbSchemaName$',
		FILENAME = 'D:\\SQLServer2017\\data\\$lower DbSchemaName$dev.dat',
		SIZE = 1000MB )
go

use $lower DbSchemaName$
go

checkpoint
go

quit
</GenFile>

</RuleSet>
