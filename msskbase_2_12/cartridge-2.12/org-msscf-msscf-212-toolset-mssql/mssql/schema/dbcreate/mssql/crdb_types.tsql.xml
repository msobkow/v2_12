<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mssql"
	Name="schema/dbcreate/mssql/crdb_types.tsql"
	Revision="2.12"
	Descr="Microsoft SQL Server Developer Edition Create Database Types T-SQL Script">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateTypes"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mssql"
		ExpansionClassName="crtypes_$lower DbSchemaName$"
		ExpansionKeyName="crtypes_$lower DbSchemaName$"
		ExpansionFileName="$dbadminfilename_CreateTypes$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
use $lower DbSchemaName$
go
$mssql_ClassCodeDataType$$iterate Types( each mssql_AddType empty empty )$
quit
</GenFile>

	<GenRule GenDef="SchemaDef" Name="mssql_ClassCodeDataType">
exec sp_addtype $lower DbSchemaName$ClassCode, "CHAR(4)"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Atom" Name="DbSchemaTypeName">$DbSchemaName$$DbColumnName$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="BlobDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="BoolDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="EnumDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Int16Def" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Int32Def" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Int64Def" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="FloatDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="DoubleDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="NumberDef" Name="mssql_AddType">
exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="StringDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TextDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="DateDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TimeDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TimestampDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TZDateDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TZTimeDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="TZTimestampDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
go
</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="UuidDef" Name="mssql_AddType">exec sp_addtype $DbSchemaTypeName$, "$clause_ColType$"
