<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mssql"
	Name="schema/dbcreate/mssql/crdb_owner.tsql"
	Revision="2.12"
	Descr="Microsoft SQL Server Developer Edition Create Database Owner T-SQL Script">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateOwner"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mssql"
		ExpansionClassName="crowner_$lower DbSchemaName$"
		ExpansionKeyName="crowner_$lower DbSchemaName$"
		ExpansionFileName="$dbadminfilename_CreateOwner$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
use master
go

if not exists (
	select *
	from master.sys.syslogins
	where name = '$lower DbSchemaName$' )
begin
	exec sp_addlogin @loginame='$lower DbSchemaName$',
		@passwd='$lower DbSchemaName$1'
<!--		@defdb='$lower DbSchemaName$'
-->end
go

if not exists (
	select *
	from master.sys.sysusers
	where name = '$lower DbSchemaName$' )
begin
	exec sp_adduser @loginame='$lower DbSchemaName$'
end
go

quit
</GenFile>

</RuleSet>
