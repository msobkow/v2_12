<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mssql"
	Name="schema/dbcreate/mssql/drdb_types.tsql"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_DropTypes"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mssql"
		ExpansionClassName="crtypes_$lower DbSchemaName$"
		ExpansionKeyName="crtypes_$lower DbSchemaName$"
		ExpansionFileName="$dbadminfilename_DropTypes$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
use $lower DbSchemaName$
go
$mssql_DropClassCodeDataType$$iterate Types( each mssql_DropDataType empty empty )$
quit
</GenFile>

	<GenRule GenDef="SchemaDef" Name="mssql_DropClassCodeDataType">
if exists ( select * from systypes where name = 'OmxClassCode' )
begin
	exec sp_droptype OmxClassCode
end
if exists ( select * from systypes where name = '$lower DbSchemaName$ClassCode' )
begin
	exec sp_droptype $lower DbSchemaName$ClassCode
end
go
</GenRule>

	<GenRule GenDef="Atom" Name="mssql_DropDataType">
if exists ( select * from systypes where name = '$DbSchemaTypeName$' )
begin
	exec sp_droptype $DbSchemaTypeName$
end
go
</GenRule>

</RuleSet>
