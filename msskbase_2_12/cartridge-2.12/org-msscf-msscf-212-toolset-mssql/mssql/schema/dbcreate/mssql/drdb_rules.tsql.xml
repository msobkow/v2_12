<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mssql"
	Name="schema/dbcreate/mssql/drdb_rules.tsql"
	Revision="2.12"
	Descr="Microsoft SQL Server Developer Edition Drop Database Rules T-SQL Script">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_DropRules"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mssql"
		ExpansionClassName="drrules_$lower DbSchemaName$"
		ExpansionKeyName="drrules_$lower DbSchemaName$"
		ExpansionFileName="$dbadminfilename_DropRules$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
use $lower DbSchemaName$
go
$iterate Types( each mssql_DropDataRule empty empty )$
quit
</GenFile>

	<GenRule ScopeDef="SchemaDef" GenDef="Atom" Name="mssql_DropDataRule">
if exists ( select * from master.sys.sysobjects where name = '$DbRuleName$' )
begin
	drop rule $DbRuleName$
end
go

if exists ( select * from sysobjects where name = '$DbRuleName$' )
begin
	drop rule $DbRuleName$
end
go
</GenRule>

</RuleSet>
