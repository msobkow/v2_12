<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="cplus"
	Name="Top"
	Revision="2.12"
	Descr="Top level rules for building files">

	<GenRule GenDef="MinorVersion" Name="top"
		>$iterate SchemaDef( each schemaFiles )$</GenRule>

	<GenRule ScopeDef="MinorVersion" GenDef="SchemaDef" Name="schemaFiles"
		>$validatePageData$$fileSchemaCPlusGitIgnore$$fileSchemaCoreGitIgnore$$fileLibSchemaDotGitIgnore$$fileCleanSchemaObjWslBash$$fileBuildSchemaObjWslBash$$fileCompileSchemaObjWslBash$$fileInstallSchemaObjWslBash$$fileConfigureAC$$fileMakefileAM$$fileSchemaISchemaHpp$$fileSchemaISchemaPublicHpp$$fileSchemaISchemaPublicCpp$$fileSchemaISchemaCpp$$fileSchemaSchemaHpp$$fileSchemaSchemaCpp$$fileSchemaSchemaPoolHpp$$fileSchemaSchemaPoolCpp$$fileSchemaAuthorizationHpp$$fileSchemaAuthorizationCpp$$fileSchemaITablePermsHpp$$fileSchemaITablePermsCpp$$fileSchemaClientConfigurationFileHpp$$fileSchemaClientConfigurationFileCpp$$fileSchemaConfigurationFileHpp$$fileSchemaConfigurationFileCpp$$fileSchemaHPKeyHpp$$fileSchemaHPKeyCpp$$fileISchemaSchemaObjHpp$$fileISchemaSchemaObjCpp$$fileSchemaSchemaObjHpp$$fileSchemaSchemaObjCpp$$fileSchemaSchemaPooledObjHpp$$fileSchemaSchemaPooledObjCpp$$fileISchemaObjPublicHpp$$fileISchemaObjPublicCpp$$iterate SchemaTables(
	each tableFiles )$--></GenRule>

	<GenRule GenDef="SchemaDef" Name="validatePageData"
		>$iterate SchemaTables( each validatePageData )$</GenRule>
	<GenRule GenDef="Table" Name="validatePageData"
		>$switch PageData yes checkPageDataNoSubclasses default empty$</GenRule>
	<GenRule GenDef="Table" Name="checkPageDataNoSubclasses"
		>$switch HasSubClasses no checkPageDataNormalizedKey default FailAssertPageDataNotAllowedForTablesWithSubclasses$</GenRule>
	<GenRule GenDef="Table" Name="checkPageDataNormalizedKey"
		>$reference BaseClass reference PrimaryKeyIndex checkPageDataNormalizedKey$</GenRule>
	<GenRule GenDef="Index" Name="checkPageDataNormalizedKey"
		>$iterate Columns( each checkPageDataNormalizedKey )$</GenRule>
	<GenRule GenDef="IndexCol" Name="checkPageDataNormalizedKey"
		>$switch IsNullable no empty default FailAssertPageDataNotAllowedForPrimaryKeyWithOptionalColumns$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="tableFiles"
		>$switch HasDefSchema yes empty default tableFilesNoDefSchema$$fileSchemaTableTableHpp$$fileSchemaTableTableCpp$$fileSchemaTableObjHpp$$fileSchemaTableObjCpp$$fileISchemaTableObjHpp$$fileISchemaTableObjCpp$$fileIObjHpp$$fileIObjCpp$$fileIEditObjHpp$$fileIEditObjCpp$$fileObjHpp$$fileObjCpp$$fileEditObjHpp$$fileEditObjCpp$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="tableFilesNoDefSchema"
		>$switch HasSuperClassRelation no fileSchemaTablePKeyHpp default empty$$switch HasSuperClassRelation no fileSchemaTablePKeyCpp default empty$$switch HasSuperClassRelation no fileSchemaTableHPKeyHpp default empty$$switch HasSuperClassRelation no fileSchemaTableHPKeyCpp default empty$$fileSchemaTableBuffHpp$$fileSchemaTableBuffCpp$$fileSchemaTableHBuffHpp$$fileSchemaTableHBuffCpp$$indexFilesNoDefSchema$</GenRule>

	<GenRule GenDef="Table" Name="indexFilesNoDefSchema"
		>$iterate Index( each indexFilesNoDefSchema )$</GenRule>

	<GenRule GenDef="Index" Name="indexFilesNoDefSchema"
		>$switch IsPrimaryIndex no fileSchemaTableIndexKeyHpp default empty$$switch IsPrimaryIndex no fileSchemaTableIndexKeyCpp default empty$</GenRule>

	<GenRule GenDef="Relation" Name="ContainerStyle">$popto TableDef ContainerStyle$</GenRule>
	<GenRule GenDef="Table" Name="ContainerStyle"
		>$switch ContainerStyleInternal
			Single ContainerStyleSingle
			None ContainerStyleNone
			empty ContainerStyleMultiple
			default ContainerStyleMultiple$</GenRule>

	<GenRule GenDef="Table" Name="ContainerStyleInternal"
		>$iterate ContainerRelations( lone ContainerStyleSingle empty ContainerStyleNone each ContainerStyleYada )$</GenRule>

	<GenRule GenDef="Object" Name="ContainerStyleYada">Yada</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleSingle">Single</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleNone">None</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleMultiple">Multiple</GenRule>

</RuleSet>
