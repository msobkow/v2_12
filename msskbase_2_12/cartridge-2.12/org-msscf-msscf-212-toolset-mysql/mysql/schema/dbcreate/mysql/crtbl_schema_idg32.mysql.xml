<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mysql"
	Name="schema/dbcreate/mysql/crtbl_schema_idg32.pgsql"
	Revision="2.12"
	Descr="null">

	<GenFile ScopeDef="SchemaDef" GenDef="Id32Gen" Name="dbadminfile_CreateSchemaIdg32Table"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mysql"
		ExpansionClassName="crtbl_$lower DbSchemaName$_idg32"
		ExpansionKeyName="crtbl_$lower DbSchemaName$_idg32"
		ExpansionFileName="$dbadminfilename_CreateSchemaIdg32Table$">--
--	@(#) $GenPackageDir$/$GenFileName$
$MssDoubleDashScriptLicense$
CREATE TABLE $lower DbSchemaName$.$DbSchemaName$_idg32 (
	slice_id	SMALLINT$clause_NotNull$,
	next_id	$clause_ColType$$clause_NotNull$ )
	ENGINE=InnoDB$RunSqlStmt$
ALTER TABLE $lower DbSchemaName$.$DbSchemaName$_idg32
	ADD CONSTRAINT pk_$lower DbSchemaName$_idg32 PRIMARY KEY (
		slice_id )$RunSqlStmt$
</GenFile>

</RuleSet>
