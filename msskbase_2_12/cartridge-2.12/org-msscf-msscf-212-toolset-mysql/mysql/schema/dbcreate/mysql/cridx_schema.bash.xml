<RuleSet
	xmlns="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://msscf.org:8088/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="mysql"
	Name="schema/dbcreate/mysql/cridx_schema.bash"
	Revision="2.12"
	Descr="null">

	<GenFile GenDef="SchemaDef" Name="dbadminfile_CreateAllIndexes"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="dbcreate"
		BasePackageName="$lower SchemaName$"
		SubPackageName="mysql"
		ExpansionClassName="cridx_$lower SchemaName$"
		ExpansionKeyName="cridx_$lower SchemaName$"
		ExpansionFileName="$dbadminfilename_CreateAllIndexes$">#!/bin/bash
#
#	@(#) $GenPackageDir$/$GenFileName$
$MssBashScriptLicense$
$parseMySqlArgs$$validateMySqlArgs$
$iterate SchemaTables( each invoke_CreateTableIndexes empty empty )$$iterate SchemaTables( each maybe_CreateTableHIndexes )$
</GenFile>

	<GenRule GenDef="Table" Name="maybe_CreateTableHIndexes">$switch BaseHasHistory yes invoke_CreateTableHIndexes default empty$</GenRule>

	<GenRule GenDef="Table" Name="invoke_CreateTableHIndexes"
		>$switch HasSuperClassRelation yes invoke_CreateTableHInhIndexes default invoke_CreateTableHBaseIndexes$</GenRule>

	<GenRule GenDef="Table" Name="invoke_CreateTableHInhIndexes"
		>$reference SuperClassRelation reference ToTable invoke_CreateTableHIndexes$$invoke_CreateTableHBaseIndexes$</GenRule>

	<GenRule GenDef="Table" Name="invoke_CreateTableHBaseIndexes"
		>$iterate Index( each maybe_CreateHIndex empty empty )$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="invoke_CreateTableIndexes">$iterate Index( each maybe_CreateIndex empty empty )$</GenRule>

	<GenRule ScopeDef="Table" GenDef="Index" Name="maybe_CreateIndex">$switch IsPrimaryIndex no maybe_CreateMappedIndex default empty$</GenRule>

	<GenRule ScopeDef="Table" GenDef="Index" Name="maybe_CreateMappedIndex">$switch IsDbMapped yes invoke_CreateIndex default empty$</GenRule>

	<GenRule ScopeDef="Table" GenDef="Index" Name="invoke_CreateIndex">echo "$dbadminfilename_CreateIndex$" &gt;&gt;$$logfilename
mysql -v -u $$mysqluser --password=$$mysqlpwd &lt; $dbadminfilename_CreateIndex$ &gt;&gt;$$logfilename 2&gt;&amp;1
</GenRule>

	<GenRule ScopeDef="Table" GenDef="Index" Name="invoke_CreateHIndex">echo "$dbadminfilename_CreateHIndex$" &gt;&gt;$$logfilename
mysql -v -u $$mysqluser --password=$$mysqlpwd &lt; $dbadminfilename_CreateHIndex$ &gt;&gt;$$logfilename 2&gt;&amp;1
</GenRule>

	<!-- GenRule ScopeDef="Table" GenDef="Index" Name="maybe_CreateHIndex">$switch IsPrimaryIndex no maybe_CreateMappedHIndex default empty$</GenRule -->

	<GenRule GenDef="Index" Name="maybe_CreateHIndex"
		><!--$switch IsPrimaryIndex no invoke_CreateHIndex default empty$--></GenRule>

	<!-- GenRule ScopeDef="Table" GenDef="Index" Name="maybe_CreateMappedHIndex">$switch IsDbMapped yes invoke_CreateHIndex default empty$</GenRule -->

</RuleSet>
