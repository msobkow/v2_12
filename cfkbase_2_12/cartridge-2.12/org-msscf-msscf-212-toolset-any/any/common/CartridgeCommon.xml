<RuleSet
	xmlns="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="any"
	Name="common/CartridgeCommon"
	Revision="2.12"
	Descr="Common expansion rules for the cartridge">

	<GenRule GenDef="Object" Name="EffShortName"
		>$switch HasShortName yes ShortName default Name$</GenRule>

	<GenRule GenDef="Object" Name="SpcAstTab"> *	</GenRule>

	<GenRule GenDef="Object" Name="JdkCollectionPackage">java.util</GenRule>

	<GenRule GenDef="Object" Name="JdkCltnExceptionPackage">java.lang</GenRule>

	<GenRule GenDef="Table" Name="BaseHasAuditColumns"
		>$switch HasSuperClassRelation yes BaseHasAuditColumnsInh default HasAuditColumns$</GenRule>

	<GenRule GenDef="Table" Name="BaseHasAuditColumnsInh"
		>$reference SuperClassRelation reference ToTable BaseHasAuditColumns$</GenRule>

	<GenRule GenDef="Table" Name="BaseHasHistory"
		>$switch HasSuperClassRelation yes BaseHasHistoryInh default BaseHasHistoryBase$</GenRule>

	<GenRule GenDef="Table" Name="BaseHasHistoryInh"
		>$reference SuperClassRelation reference ToTable BaseHasHistory$</GenRule>

	<GenRule GenDef="Table" Name="BaseHasHistoryBase"
		>$HasHistory$</GenRule>

	<GenRule GenDef="Index" Name="BaseHasHistory"
		>$reference FromTable BaseHasHistory$</GenRule>

	<GenRule GenDef="Table" Name="BaseHasClassCode"
		>$switch HasSuperClassRelation yes implBaseHasClassCodeInh default implBaseHasClassCodeBase$</GenRule>

	<GenRule GenDef="Table" Name="implBaseHasClassCodeInh"
		>$reference SuperClassRelation reference ToTable BaseHasClassCode$</GenRule>

	<GenRule GenDef="Table" Name="implBaseHasClassCodeBase"
		>$switch HasSubClasses yes yes default no$</GenRule>

</RuleSet>
