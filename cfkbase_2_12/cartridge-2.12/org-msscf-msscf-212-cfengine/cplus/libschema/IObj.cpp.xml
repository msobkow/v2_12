<RuleSet
	xmlns="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="cplus"
	Name="libschema/IObj.cpp"
	Revision="2.12"
	Descr="C++18 Table Object interface implementation">

	<GenFile GenDef="Table" Name="fileIObjCpp"
			GenerateOnce="false"
			ModuleName=""
		SourceBundle="cplus"
		BasePackageName="libcfcore"
		SubPackageName=""
		ExpansionClassName="I$SchemaName$$TableName$ObjCpp"
		ExpansionKeyName="I$SchemaName$$TableName$ObjCpp"
		ExpansionFileName="I$SchemaName$$TableName$Obj.cpp"
>// Description: C++18 Object interface implementation for $SchemaName$ $TableName$.

$MssSourceLicense$

#include &lt;cflib/ICFLibPublic.hpp&gt;

using namespace std;

#include &lt;$lower SchemaName$/I$SchemaName$Public.hpp&gt;
#include &lt;$lower SchemaName$obj/I$SchemaName$ObjPublic.hpp&gt;$CPlusObjInclude$

namespace $CPlusNamespace$ {

	I$SchemaName$$TableName$Obj::I$SchemaName$$TableName$Obj()$switch HasSuperClassRelation yes implIObjConstructSuperClassForm default implIObjConstructBaseForm$
	{
	}

	I$SchemaName$$TableName$Obj::~I$SchemaName$$TableName$Obj() {
	}
}
</GenFile>

	<GenRule GenDef="Table" Name="implIObjConstructSuperClassForm">
	: I$reference SuperClassRelation reference ToTable SchemaName$$reference SuperClassRelation reference ToTable TableName$Obj()</GenRule>

	<GenRule GenDef="Table" Name="implIObjConstructBaseForm">
	: cflib::ICFLibAnyObj()</GenRule>

</RuleSet>
