<RuleSet
	xmlns="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:xs="http://www.w3.org/2001/XMLSchema"
	xsi:schemaLocation="http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd http://mcf.markhome.server/msscf/2.0.12/xsd/cfgenkb-2.12-ruleset.xsd"
	ToolSet="java"
	Name="Top"
	Revision="2.12"
	Descr="Top level rules for building files">

	<GenRule GenDef="MinorVersion" Name="top"
		>$iterate SchemaDef( each schemaFiles )$</GenRule>

	<GenRule GenDef="Relation" Name="ToTableHasClassCode"
		>$reference ToTable HasClassCode$</GenRule>

	<GenRule GenDef="Relation" Name="ToTableHasLookupIndex"
		>$reference ToTable HasLookupIndex$</GenRule>

	<GenRule GenDef="Relation" Name="ToTableHasInheritedLookupIndex"
		>$reference ToTable HasInheritedLookupIndex$</GenRule>

	<GenRule GenDef="Relation" Name="FromTableHasClassCode"
		>$reference FromTable HasClassCode$</GenRule>

	<GenRule GenDef="Relation" Name="FromTableHasLookupIndex"
		>$reference FromTable HasLookupIndex$</GenRule>

	<GenRule GenDef="Relation" Name="FromTableHasInheritedLookupIndex"
		>$reference FromTable HasInheritedLookupIndex$</GenRule>

	<GenRule GenDef="Table" Name="HasInheritedLookupIndex"
		>$switch HasLookupIndex yes yes default maybeInheritedLookupIndex$</GenRule>

	<GenRule GenDef="Table" Name="maybeInheritedLookupIndex"
		>$switch HasSuperClassRelation yes inheritedLookupIndex default no$</GenRule>

	<GenRule GenDef="Table" Name="inheritedLookupIndex"
		>$reference SuperClassRelation reference ToTable HasInheritedLookupIndex$</GenRule>

	<GenRule GenDef="RelationCol" Name="ToTableHasClassCode"
		>$reference Relation reference ToTable HasClassCode$</GenRule>

	<GenRule GenDef="RelationCol" Name="ToTableHasLookupIndex"
		>$reference Relation reference ToTable HasLookupIndex$</GenRule>

	<GenRule ScopeDef="MinorVersion" GenDef="SchemaDef" Name="schemaFiles"
		>$validatePageData$$fileSchemaJavaGitIgnore$$fileSchemaBinGitIgnore$$fileSchemaCoreGitIgnore$$fileSchemaRamGitIgnore$$fileSchemaCorePOM$$fileSchemaRamPOM$$fileSchemaNetServerConfig$$fileSchemaISchemaJava$$fileSchemaSchemaJava$$fileSchemaSchemaPoolJava$$fileSchemaAuthorizationJava$$fileSchemaITablePermsJava$$fileSchemaClientConfigurationFileJava$$fileSchemaConfigurationFileJava$$fileSchemaNetServerSchemaJava$$fileSchemaAuthNetServerJava$$fileSchemaHPKeyJava$$fileISchemaSchemaObjJava$$fileSchemaSchemaObjJava$$fileSchemaSchemaPooledObjJava$$fileSchemaRamSchemaJava$$iterate SchemaTables(
	each tableFiles )$</GenRule>

	<GenRule GenDef="SchemaDef" Name="validatePageData"
		>$iterate SchemaTables( each validatePageData )$</GenRule>
	<GenRule GenDef="Table" Name="validatePageData"
		>$switch PageData yes checkPageDataNoSubclasses default empty$</GenRule>
	<GenRule GenDef="Table" Name="checkPageDataNoSubclasses"
		>$switch HasSubClasses no checkPageDataNormalizedKey default FailAssertPageDataNotAllowedForTablesWithSubclasses$</GenRule>
	<GenRule GenDef="Table" Name="checkPageDataNormalizedKey"
		>$reference BaseClass reference PrimaryKeyIndex checkPageDataNormalizedKey$</GenRule>
	<GenRule GenDef="Index" Name="checkPageDataNormalizedKey"
		>$iterate Columns( each checkPageDataNormalizedKey )$</GenRule>
	<GenRule GenDef="IndexCol" Name="checkPageDataNormalizedKey"
		>$switch IsNullable no empty default FailAssertPageDataNotAllowedForPrimaryKeyWithOptionalColumns$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="tableFiles"
		>$switch HasDefSchema yes empty default tableFilesNoDefSchema$$fileSchemaTableFactoryJava$$fileSchemaTableTableJava$$fileSchemaTableDefaultFactoryJava$$fileSchemaNetServerTableTableJava$$fileSchemaTableObjJava$$fileISchemaTableObjJava$$fileIObjJava$$fileIEditObjJava$$fileObjJava$$fileEditObjJava$$fileSchemaRamTableTableJava$$iterate Index( each indexFiles )$$iterate DispensedId16Generators( first fileSchemaRamTableId16GenJava each empty empty empty )$$iterate DispensedId32Generators( first fileSchemaRamTableId32GenJava each empty empty empty )$$iterate DispensedId64Generators( first fileSchemaRamTableId64GenJava each empty empty empty )$</GenRule>

	<GenRule ScopeDef="SchemaDef" GenDef="Table" Name="tableFilesNoDefSchema"
		>$switch HasSuperClassRelation no fileSchemaTablePKeyJava default empty$$switch HasSuperClassRelation no fileSchemaTableHPKeyJava default empty$$fileSchemaTableBuffJava$$fileSchemaTableHBuffJava$$iterate Index( each indexFilesNoDefSchema empty empty )$</GenRule>

	<GenRule GenDef="Index" Name="indexFilesNoDefSchema"
		>$switch IsPrimaryIndex no fileSchemaTableIndexKeyJava default empty$</GenRule>

	<GenRule GenDef="Index" Name="indexFiles"
		></GenRule>

	<GenRule GenDef="Relation" Name="ContainerStyle">$popto TableDef ContainerStyle$</GenRule>
	<GenRule GenDef="Table" Name="ContainerStyle"
		>$switch ContainerStyleInternal
			Single ContainerStyleSingle
			None ContainerStyleNone
			empty ContainerStyleMultiple
			default ContainerStyleMultiple$</GenRule>

	<GenRule GenDef="Table" Name="ContainerStyleInternal"
		>$iterate ContainerRelations( lone ContainerStyleSingle empty SuperOrContainerStyleNone each ContainerStyleYada )$</GenRule>

	<GenRule GenDef="Object" Name="SuperOrContainerStyleNone"
		>$switch ObjectTableHasSuperClassRelation yes SuperContainerStyle default ContainerStyleNone$</GenRule>

	<GenRule GenDef="Object" Name="SuperContainerStyle"
		>$popto Table reference SuperClassRelation reference ToTable ContainerStyleInternal$</GenRule>

	<GenRule GenDef="Object" Name="ContainerStyleYada">Yada</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleSingle">Single</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleNone">None</GenRule>
	<GenRule GenDef="Object" Name="ContainerStyleMultiple">Multiple</GenRule>

</RuleSet>
